<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.keith.expensesplitter.ui.fragments.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_makeGroupFragment"
            app:destination="@id/makeGroupFragment" />
        <action
            android:id="@+id/action_homeFragment_to_previousGroupsFragment"
            app:destination="@id/previousGroupsFragment" />
    </fragment>
    <fragment
        android:id="@+id/makeGroupFragment"
        android:name="com.keith.expensesplitter.ui.fragments.MakeGroupFragment"
        android:label="fragment_make_expense"
        tools:layout="@layout/fragment_make_expense" />
    <fragment
        android:id="@+id/previousGroupsFragment"
        android:name="com.keith.expensesplitter.ui.fragments.PreviousGroupsFragment"
        android:label="fragment_previous_expense_groups"
        tools:layout="@layout/fragment_previous_expense_groups" />
</navigation>